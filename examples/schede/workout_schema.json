{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Workout Schema",
  "type": "object",
  "required": ["id", "nome", "giorni"],
  "properties": {
    "id": { "type": "string", "description": "Identificativo univoco della scheda" },
    "nome": { "type": "string", "description": "Nome leggibile della scheda" },
    "descrizione": { "type": ["string", "null"], "description": "Descrizione opzionale" },
    "categoria": { "type": ["string", "null"], "description": "Categoria opzionale" },
    "giorni": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["giorno", "esercizi"],
        "properties": {
          "giorno": { "type": "string", "description": "Etichetta del giorno (es. Giorno 1)" },
          "etichetta": { "type": ["string", "null"], "description": "Nome leggibile del giorno" },
          "esercizi": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "nome", "serie", "reps"],
              "properties": {
                "id": { "type": "string", "description": "Identificativo unico esercizio (es. panca_piana)" },
                "nome": { "type": "string", "description": "Nome visualizzato dell'esercizio" },
                "serie": { "type": "integer", "minimum": 1, "description": "Numero di serie" },
                "reps": { "type": "string", "description": "Ripetizioni (es. 8-10 o AMRAP)" },
                "recupero": { "type": ["integer", "null"], "minimum": 0, "description": "Recupero in secondi (opzionale)" },
                "video": { "type": ["string", "null"], "format": "uri", "description": "URL al video (es. YouTube) dell'esercizio (opzionale)" },
                "note": { "type": ["string", "null"], "description": "Note opzionali" },
                "tipo": { "type": ["string", "null"], "enum": ["cardio", null], "description": "Tipo esercizio: 'cardio' per tapis roulant/cyclette, omesso per esercizi con peso" },
                "durata": { "type": ["integer", "null"], "minimum": 1, "description": "Durata target in minuti (opzionale, solo per esercizi cardio)" }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
